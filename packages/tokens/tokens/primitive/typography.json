{
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": { "$value": "Inter, ui-sans-serif, system-ui, -apple-system, sans-serif" },
      "mono": { "$value": "JetBrains Mono, ui-monospace, SFMono-Regular, monospace" }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": "0.75rem" },
      "sm": { "$value": "0.875rem" },
      "base": { "$value": "1rem" },
      "lg": { "$value": "1.125rem" },
      "xl": { "$value": "1.25rem" },
      "2xl": { "$value": "1.5rem" },
      "3xl": { "$value": "1.875rem" },
      "4xl": { "$value": "2.25rem" }
    },
    "weight": {
      "$type": "fontWeight",
      "normal": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    },
    "lineHeight": {
      "$type": "dimension",
      "tight": { "$value": "1.25" },
      "normal": { "$value": "1.5" },
      "relaxed": { "$value": "1.625" }
    }
  }
}
